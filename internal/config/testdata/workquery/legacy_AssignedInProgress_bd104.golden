sh -c 'for id in "$GC_SESSION_ID" "$GC_SESSION_NAME" "$GC_ALIAS"; do [ -z "$id" ] && continue; legacy=""; case "$id" in *control-dispatcher) legacy="${id%control-dispatcher}workflow-control";; esac; for cand in "$id" "$legacy"; do [ -z "$cand" ] && continue; r=$(bd list --status in_progress --assignee="$cand" --json --limit=1 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; r=$(bd query --json '\''ephemeral=true AND status=in_progress'\'' --limit=0 2>/dev/null | jq --arg id "$cand" '\''[.[] | select((.assignee // "") == $id)] | .[:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; done; done; printf "[]"'