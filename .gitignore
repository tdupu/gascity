.cache/

# Bugflow policy — strictly local state, configured per operator
.github/bugflow.toml

.vscode/settings.json
.env
/gen-client

# Developer scratch — diff dumps and ad-hoc patches created during review
tmp_*.diff
tmp_*.patch
issues.jsonl

# Python bytecode from script tests
__pycache__/

